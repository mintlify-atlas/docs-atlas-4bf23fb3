  "keyFeatures": [
    "Dynamic column mapping configured at runtime — no hardcoded schema",
    "Incremental loading using business keys to prevent duplicate records",
    "Multiple transform types: upper/lower case, date component extraction (year/month/day), and column concatenation",
    "Dual-database architecture: reads from OLTP (SQL Server), writes to OLAP Data Warehouse",
    "Interactive Streamlit dashboard for no-code ETL configuration and execution",
    "Custom SQL query support as an alternative to full-table extraction",
    "Column preview with data types shown in the UI before running ETL",
    "Automated test suite with pytest covering all ETL layers"
  ],
